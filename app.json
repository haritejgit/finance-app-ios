{
  "expo": {
    "name": "Finance Manager",
    "slug": "finance-manager",
    "scheme": "financemanager",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1565C0"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.haritej.financeapp",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We use your location to tag customer home addresses.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.haritej.financeapp"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    }
  }
}
