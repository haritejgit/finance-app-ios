rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function ownsExistingDoc() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    function createsOwnDoc() {
      return isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    function keepsOwnerImmutable() {
      return request.resource.data.userId == resource.data.userId;
    }

    function validNonNegative(field) {
      return !request.resource.data.keys().hasAny([field]) ||
        (request.resource.data[field] is number && request.resource.data[field] >= 0);
    }

    function validLoanAmounts() {
      return validNonNegative('principalAmount') &&
        validNonNegative('interestAmount') &&
        validNonNegative('totalPayable') &&
        validNonNegative('balanceAmount');
    }

    function validPaymentAmount() {
      return validNonNegative('amountPaid');
    }

    match /users/{uid} {
      allow read, create, update, delete: if isSignedIn() && request.auth.uid == uid;
    }

    match /villages/{docId} {
      allow read: if ownsExistingDoc();
      allow create: if createsOwnDoc();
      allow update: if ownsExistingDoc() && keepsOwnerImmutable();
      allow delete: if ownsExistingDoc();
    }

    match /customers/{docId} {
      allow read: if ownsExistingDoc();
      allow create: if createsOwnDoc();
      allow update: if ownsExistingDoc() && keepsOwnerImmutable();
      allow delete: if ownsExistingDoc();
    }

    match /loans/{docId} {
      allow read: if ownsExistingDoc();
      allow create: if createsOwnDoc() && validLoanAmounts();
      allow update: if ownsExistingDoc() && keepsOwnerImmutable() && validLoanAmounts();
      allow delete: if ownsExistingDoc();
    }

    match /payments/{docId} {
      allow read: if ownsExistingDoc();
      allow create: if createsOwnDoc() && validPaymentAmount();
      allow update: if ownsExistingDoc() && keepsOwnerImmutable() && validPaymentAmount();
      allow delete: if ownsExistingDoc();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
